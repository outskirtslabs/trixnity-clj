{:deps  {}
 :paths []
 :tasks {:requires
         ([clojure.string :as str]
          [clojure.pprint :refer [print-table]]
          [babashka.tasks :refer [shell]])

         :init
         (do (def paths ["src" "dev" "test"]))

         dev
         {:doc  "Start a local development server"
          :task (apply clojure "-M:repl/dev:dev" *command-line-args*)}

         test
         {:doc     "Run all tests or specific test suites"
          :depends [bridge:build]
          :task    (apply clojure "-M:dev:kaocha:bridge" *command-line-args*)}

         poc:run
         {:doc  "Run Phase 2 Clojure interop POC entrypoint"
          :task (apply clojure "-M:dev -m ol.trixnity-poc.main" *command-line-args*)}

         poc:facade:run
         {:doc  "Run Phase 3 facade POC entrypoint"
          :task (apply clojure "-M:dev:bridge -m ol.trixnity-poc.facade-main" *command-line-args*)}

         poc:test
         {:doc     "Run only Phase 2 POC tests"
          :depends [bridge:build]
          :task    (apply clojure
                          "-M:dev:kaocha:bridge"
                          "--focus" ":ol.trixnity-poc.bot-logic-test"
                          "--focus" ":ol.trixnity-poc.config-test"
                          "--focus" ":ol.trixnity-poc.invite-error-test"
                          "--focus" ":ol.trixnity-poc.room-state-test"
                          "--focus" ":ol.trixnity-poc.synapse-register-test"
                          *command-line-args*)}

         poc:facade:test
         {:doc     "Run only Phase 3.5 facade POC tests"
          :depends [bridge:build]
          :task    (apply clojure
                          "-M:dev:kaocha:bridge"
                          "--focus" ":ol.trixnity-poc.facade-main-test"
                          *command-line-args*)}

         facade:test
         {:doc     "Run only Phase 3.4 facade tests"
          :depends [bridge:build]
          :task    (apply clojure
                          "-M:dev:kaocha:bridge"
                          "--focus" ":ol.trixnity.client-test"
                          *command-line-args*)}

         poc:repl
         {:doc  "Start REPL for Phase 2 POC work"
          :task (apply clojure "-M:repl/dev:dev" *command-line-args*)}

         versions:sync
         {:doc  "Sync trixnity version from deps.edn into managed files"
          :task (apply clojure "-X" "ol.trixnity.phase3/versions-sync" *command-line-args*)}

         versions:verify
         {:doc  "Verify managed files match trixnity version from deps.edn"
          :task (apply clojure "-X" "ol.trixnity.phase3/versions-verify" *command-line-args*)}

         bridge:gen
         {:doc  "Generate Kotlin bridge sources from bridge-spec.edn"
          :task (apply clojure "-X" "ol.trixnity.phase3/bridge-gen" *command-line-args*)}

         bridge:build
         {:doc     "Compile the Kotlin bridge classes"
          :task    (shell "gradle -p kotlin-bridge classes")}

         bridge:jar
         {:doc     "Build the Kotlin bridge jar"
          :task    (shell "gradle -p kotlin-bridge jar")}

         interop:gen
         {:doc  "Generate Clojure interop namespace from bridge-spec.edn"
          :task (apply clojure "-X" "ol.trixnity.phase3/interop-gen" *command-line-args*)}

         interop:verify
         {:doc  "Verify Clojure interop namespace is up-to-date"
          :task (apply clojure "-X" "ol.trixnity.phase3/interop-verify" *command-line-args*)}

         interop:test
         {:doc     "Run interop/codegen/phase3 generation tests"
          :depends [bridge:build]
          :task    (apply clojure
                          "-M:dev:kaocha:bridge"
                          "--focus" ":ol.trixnity.phase3-test"
                          *command-line-args*)}

         fmt
         {:doc  "Format code with cljfmt"
          :task (apply shell "cljfmt --quiet -v fix" (if (seq *command-line-args*) *command-line-args* paths))}

         fmt:check
         {:doc  "Check code formatting without making changes"
          :task (apply shell "cljfmt check " paths)}

         prep
         {:doc  "Prepare Clojure dependencies"
          :task (apply clojure "-X:deps prep :aliases '[:dev :kaocha]'")}

         deps-tree
         {:doc  "Show dependency tree"
          :task (clojure "-X:deps tree :aliases '[:dev]'")}

         lint:copy-configs
         {:doc  "Copy clj-kondo configs from dependencies"
          :task (shell "clj-kondo" "--lint" (-> (shell {:out :string} "clojure -Spath -M:test:dev") :out str/trim) "--dependencies" "--copy-configs" "--skip-lint")}

         lint
         {:doc  "Lint code with clj-kondo"
          :task (if (seq *command-line-args*)
                  (apply shell "clj-kondo" "--lint" *command-line-args*)
                  (apply shell "clj-kondo --lint" paths))}

         qa
         {:doc     "Run full quality assurance: format, lint, and test"
          :depends [versions:verify interop:verify fmt lint test]}

         ci
         {:doc     "Run CI checks: version pins, test, format check, and lint"
          :depends [versions:verify interop:verify test fmt:check lint]}

         jar                                                                                                                                                         {:override-builtin true
                                                                                                                                                                      :depends          [clean]
                                                                                                                                                                      :doc              "Build an jar"
                                                                                                                                                                      :task             (shell "clojure -T:build jar")}

         clean                                                                                                                                                       {:override-builtin true
                                                                                                                                                                      :doc              "Clean build artifacts"
                                                                                                                                                                      :task             (shell "clojure -T:build clean")}

         publish                                                                                                                                                     {:doc     "Publish the clojure sdk libs to clojars"
                                                                                                                                                                      :depends [jar]
                                                                                                                                                                      :task    (clojure "-T:build deploy")}}}
